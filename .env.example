# Configurações do Banco de Dados
DB_HOST=localhost
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_NAME=precompeonato
DB_PORT=3306

# Porta do servidor
PORT=3000

# Ambiente (development ou production)
NODE_ENV=development

# Configurações de Email (para autenticação)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_app
EMAIL_FROM=Precompeonato <noreply@precompeonato.com.br>

# JWT/Session Secret
SESSION_SECRET=sua_chave_secreta_aqui_mude_em_producao

# Modo Beta (true = oculta login, inscrição, perfil, mesas casuais, ranking)
BETA_MODE=false
